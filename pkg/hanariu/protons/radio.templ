package hanariu

import "github.com/Discorder20/raw-h/pkg/hanariu"

type RadioBosons struct {
	Error bool
	Attrs hanariu.Attrs
}

var radioStyles = hanariu.Boson{
	"default": "radio-default",
	"noerror": "radio-noerror",
	"error":   "radio-error",
}

func Radio(props *RadioBosons) templ.Component {
	attrs := make(hanariu.Attrs)
	for k, v := range props.Attrs {
		attrs[k] = v
	}
	attrs["type"] = "radio"
	return hanariu.CreateComponent("input", getRadioClasses(props.Error), attrs, true)
}

func getRadioClasses(err bool) string {
	var classes = radioStyles["default"] + " "
	if err {
		classes += radioStyles["error"]
	} else {
		classes += radioStyles["noerror"]
	}
	return classes
}

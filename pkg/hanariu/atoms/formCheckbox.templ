package hanariu

import (
	"github.com/Discorder20/raw-h/pkg/hanariu"
	protons "github.com/Discorder20/raw-h/pkg/hanariu/protons"
)

type FormCheckboxBosons struct {
	Error   bool
	Checked bool
	Attrs   hanariu.Attrs
}

templ FormCheckbox(props *FormCheckboxBosons) {
	<div class="formcheckbox-284">
		@protons.Checkbox(&protons.CheckboxBosons{Attrs: getFormCheckboxAttrs(props), Error: props.Error})
		{ children... }
	</div>
}

func getFormCheckboxAttrs(props *FormCheckboxBosons) hanariu.Attrs {
	attrs := props.Attrs
	if props.Checked {
		attrs["checked"] = ""
	}
	return attrs
}

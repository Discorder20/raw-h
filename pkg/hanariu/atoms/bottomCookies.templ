package hanariu

import "github.com/Discorder20/raw-h/pkg/hanariu"

var bottomCookiesStyles = hanariu.Boson{
	"bottomCookies":  "bottomcookies-bottomcookies",
	"default":        "bottomcookies-default",
	"content":        "bottomcookies-content",
	"slideContainer": "bottomcookies-slidecontainer",
}

func bottomCookiesContent() templ.Component {
	attrs := make(hanariu.Attrs)
	var bind = "{['data-x-transition:enter']: 'bottomcookies-transition-enter',['data-x-transition:enter-start']: 'bottomcookies-transition-enter-from',['data-x-transition:enter-end']: 'bottomcookies-transition-enter-to',['data-x-transition:leave']: 'bottomcookies-transition-enter',['data-x-transition:leave-start']: 'bottomcookies-transition-enter-to',['data-x-transition:leave-end']: 'bottomcookies-transition-enter-from'"
	bind += "}"
	attrs["data-x-show"] = "$store.cookies.show === true"
	attrs["data-x-bind"] = bind

	return hanariu.CreateComponent("div", bottomCookiesStyles["content"], attrs, false)
}

templ BottomCookies() {
	<div
		data-x-data
		data-x-bind={ "{['data-x-bind:class']() { $store.cookies.show === true ? 'z-40' : '' }}" }
		class={ bottomCookiesStyles["bottomCookies"] }
	>
		<template data-x-teleport="body">
			<div
				class={ bottomCookiesStyles["default"] }
				data-x-show={ "$store.cookies.show === true" }
				data-x-cloak
			>
				@bottomCookiesContent() {
					<div class={ bottomCookiesStyles["slideContainer"] }>
						{ children... }
					</div>
				}
			</div>
		</template>
	</div>
}
